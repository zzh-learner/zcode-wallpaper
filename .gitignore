# Dependencies (install with: npm install)
node_modules/

# Local logs generated by the launcher (your machine's runtime output)
zcode-launch.log
*-launch.log
verify-*.log

# Your private wallpaper images — DO NOT commit personal photos.
# Keep wallpaper.svg (the bundled test image). Add your own images here
# or name them with a prefix to ignore:
*.jpg
*.jpeg
*.png
*.bmp
!wallpaper.svg
!EffectPreview.png

# Everything under wallpapers/ is private (any format). Ignore the
# contents but keep the directory itself in the repo via .gitkeep.
wallpapers/*
!wallpapers/.gitkeep

# OS / editor cruft
Thumbs.db
Desktop.ini
.DS_Store
*.swp
.vscode/
.idea/
