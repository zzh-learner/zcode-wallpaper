# Dependencies (install with: npm install)
node_modules/

# Local logs generated by the launcher (your machine's runtime output)
zcode-launch.log
*-launch.log
verify-*.log

# Your private wallpaper images — DO NOT commit personal photos.
# Add your own images to wallpapers/ (ignored below) or name them with
# a prefix to ignore:
*.jpg
*.jpeg
*.png
*.bmp
!EffectPreview.png

# Video wallpaper assets (mp4/webm/mov dropped into wallpapers-video/).
# Same privacy rule as images: never commit personal videos.
*.mp4
*.webm
*.mov

# Everything under wallpapers/ is private (any format). Ignore the
# contents but keep the directory itself in the repo via .gitkeep.
wallpapers/*
!wallpapers/.gitkeep

# Same for wallpapers-video/: contents private, keep the dir via .gitkeep.
wallpapers-video/*
!wallpapers-video/.gitkeep

# Resized wallpaper thumbnails (generated by resize.cjs from wallpapers/)
wallpapers-thumb/

# Brainstorming visual companion (local only)
.superpowers/

# OS / editor cruft
Thumbs.db
Desktop.ini
.DS_Store
*.swp
.vscode/
.idea/

# Windows reserved device name: `>nul` / `2>nul` redirects run from Git Bash
# create a literal file named `nul` instead of hitting the NUL device.
# Never commit it; clean it up locally when it appears.
nul

# Novel text files (private content, never commit).
# Add your .txt to novels/ (ignored below) — same privacy rule as wallpapers/.
novels/*
!novels/.gitkeep
